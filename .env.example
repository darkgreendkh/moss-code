# Copy this file to .env and fill only the providers you use.

# Optional provider selector. CLI --provider still takes precedence.
MOSS_PROVIDER=deepseek

# Recommended default. DeepSeek uses its Anthropic-compatible endpoint.
MOSS_DEEPSEEK_API_BASE=https://api.deepseek.com/anthropic
MOSS_DEEPSEEK_API_KEY=
MOSS_DEEPSEEK_MODEL=deepseek-v4-pro

# Optional right.codes shared key. Used by --provider openai and --provider anthropic when provider-specific keys are empty.
MOSS_RIGHT_CODES_API_KEY=

# Default OpenAI-compatible endpoint. Change this if you use another /responses-compatible service.
MOSS_OPENAI_API_BASE=https://api.openai.com/v1
MOSS_OPENAI_API_KEY=
MOSS_OPENAI_MODEL=gpt-5.4

# Default Anthropic-compatible endpoint. Can reuse MOSS_RIGHT_CODES_API_KEY when your gateway shares one key.
MOSS_ANTHROPIC_API_BASE=https://api.anthropic.com/v1
MOSS_ANTHROPIC_API_KEY=
MOSS_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional comma-separated extra env names to redact from traces and reports.
MOSS_SECRET_ENV_NAMES=
